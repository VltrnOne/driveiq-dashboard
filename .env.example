# ─── Database ──────────────────────────────────────────────────
# Development (SQLite — zero config)
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL)
# DATABASE_URL="postgresql://driveiq:password@localhost:5432/driveiq"

# ─── JWT Auth ──────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_BYTE_HEX
JWT_EXPIRATION=8h

# ─── Vision Service ────────────────────────────────────────────
VISION_SERVICE_URL=http://localhost:8010
VISION_API_KEY=CHANGE_ME_STRONG_RANDOM_KEY
NEXT_PUBLIC_VISION_URL=http://localhost:8010

# ─── Webhook Security ──────────────────────────────────────────
WEBHOOK_SECRET=CHANGE_ME_SHARED_SECRET

# ─── Claude AI (Order Suggestions) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001
SUGGESTIONS_MAX_TOKENS=512
SUGGESTIONS_ENABLED=true

# ─── Business Config ───────────────────────────────────────────
TAX_RATE=0.0875
POINTS_PER_DOLLAR=10
TIER_SILVER_THRESHOLD=500
TIER_GOLD_THRESHOLD=1500
TIER_PLATINUM_THRESHOLD=5000
USUAL_ORDER_THRESHOLD=0.70

# ─── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
